---
import { nav, site } from '../data/site';
---

<header class="site-header" data-header>
  <div class="site-header__inner">
    <a href="/" class="brand" aria-label={`${site.name} — home`}>
      <span class="brand__l1">Stories</span>
      <span class="brand__l2">Beyond&nbsp;Frames</span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul class="reset primary-nav__list">
        {nav.map((item) => (
          <li><a href={item.href} class="primary-nav__link">{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <button class="menu-toggle" data-menu-open aria-label="Open menu" aria-expanded="false" aria-controls="overlay-menu">
      <span></span><span></span>
    </button>
  </div>
</header>

<div class="overlay-menu" id="overlay-menu" data-overlay hidden>
  <button class="menu-toggle menu-toggle--close" data-menu-close aria-label="Close menu">
    <span></span><span></span>
  </button>
  <nav class="overlay-menu__nav" aria-label="Overlay">
    <ul class="reset">
      <li><a href="/" class="overlay-menu__link">Home</a></li>
      {nav.map((item) => (
        <li><a href={item.href} class="overlay-menu__link">{item.label}</a></li>
      ))}
    </ul>
  </nav>
  <div class="overlay-menu__foot">
    <a href={`mailto:${site.email}`}>{site.email}</a>
    <a href={site.instagram.url} target="_blank" rel="noopener">{site.instagram.handle}</a>
  </div>
</div>

<style>
  .site-header {
    position: absolute;
    inset: 0 0 auto 0;
    z-index: 50;
    padding-block: clamp(1.4rem, 2.6vw, 2.2rem);
  }
  .site-header__inner {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  /* Wordmark */
  .brand {
    display: grid;
    line-height: 1.18;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.34em;
    font-size: 0.74rem;
    font-weight: 400;
    color: var(--ink);
  }
  .brand__l2 { padding-left: 0.06em; }

  /* Desktop nav */
  .primary-nav__list {
    display: flex;
    gap: clamp(1.4rem, 2.6vw, 2.8rem);
    align-items: center;
  }
  .primary-nav__link {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: 0.74rem;
    color: var(--ink);
    position: relative;
    padding-bottom: 0.25rem;
  }
  .primary-nav__link::after {
    content: '';
    position: absolute;
    left: 0; bottom: 0;
    height: 1px; width: 100%;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.45s var(--ease-out);
  }
  .primary-nav__link:hover::after { transform: scaleX(1); transform-origin: left; }

  /* Hamburger */
  .menu-toggle {
    display: none;
    width: 30px; height: 22px;
    position: relative;
    flex: none;
  }
  .menu-toggle span {
    position: absolute;
    left: 0; right: 0;
    height: 1.5px;
    background: var(--ink);
    transition: transform 0.4s var(--ease), opacity 0.3s var(--ease);
  }
  .menu-toggle span:nth-child(1) { top: 4px; }
  .menu-toggle span:nth-child(2) { top: 13px; }

  /* Overlay menu */
  .overlay-menu {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: var(--bone);
    display: grid;
    grid-template-rows: 1fr auto;
    place-items: center;
    opacity: 0;
    transition: opacity 0.5s var(--ease);
  }
  .overlay-menu[hidden] { display: none; }
  .overlay-menu.is-open { opacity: 1; }
  .menu-toggle--close {
    display: block;
    position: absolute;
    top: clamp(1.6rem, 3vw, 2.4rem);
    right: var(--gutter);
    width: 26px; height: 26px;
  }
  .menu-toggle--close span { top: 12px; }
  .menu-toggle--close span:nth-child(1) { transform: rotate(45deg); }
  .menu-toggle--close span:nth-child(2) { transform: rotate(-45deg); }

  .overlay-menu__nav ul {
    display: grid;
    gap: clamp(1.1rem, 3.4vw, 1.9rem);
    text-align: center;
  }
  .overlay-menu__link {
    font-family: var(--font-serif);
    font-weight: 360;
    font-size: clamp(1.9rem, 7vw, 3rem);
    color: var(--ink);
    transition: color 0.35s var(--ease);
  }
  .overlay-menu__link:hover { color: var(--accent-deep); font-style: italic; }
  .overlay-menu__foot {
    align-self: end;
    padding-bottom: clamp(2rem, 6vw, 3.5rem);
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }

  @media (max-width: 820px) {
    .primary-nav { display: none; }
    .menu-toggle { display: block; }
    .brand { font-size: 0.7rem; letter-spacing: 0.28em; }
  }
</style>

<script>
  function initMenu() {
    const overlay = document.querySelector<HTMLElement>('[data-overlay]');
    const openBtn = document.querySelector<HTMLButtonElement>('[data-menu-open]');
    const closeBtn = document.querySelector<HTMLButtonElement>('[data-menu-close]');
    if (!overlay || !openBtn) return;

    const open = () => {
      overlay.hidden = false;
      requestAnimationFrame(() => overlay.classList.add('is-open'));
      openBtn.setAttribute('aria-expanded', 'true');
      document.documentElement.style.overflow = 'hidden';
    };
    const close = () => {
      overlay.classList.remove('is-open');
      openBtn.setAttribute('aria-expanded', 'false');
      document.documentElement.style.overflow = '';
      window.setTimeout(() => { overlay.hidden = true; }, 500);
    };

    openBtn.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);
    overlay.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.hidden) close();
    });
  }

  initMenu();
  document.addEventListener('astro:page-load', initMenu);
</script>
