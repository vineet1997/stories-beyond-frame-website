---
import Frame from '../Frame.astro';
import { closing } from '../../data/photos';
---

<section class="closing section">
  <div class="container closing__inner">
    <div class="closing__lead reveal">
      <h2 class="closing__head">
        If you see beauty the way we do, we'd love to hear from you.
      </h2>
    </div>

    <div class="closing__body">
      <div class="closing__img closing__img--a reveal">
        <Frame image={closing[0].image} alt={closing[0].alt} ratio="2 / 3"
          sizes="(max-width: 760px) 86vw, 34vw" />
      </div>

      <div class="closing__text reveal">
        <p>
          Our photographs will outlive us. That is why we chase the real and the
          unrehearsed — the stolen glance, the quiet touch, the laughter between
          rituals.
        </p>
        <p>
          We document with presence and restraint, so that years from now your
          story still feels like the day it happened. Photography and films, for
          couples who want their celebration kept honestly and beautifully.
        </p>
      </div>

      <div class="closing__img closing__img--b reveal">
        <Frame image={closing[1].image} alt={closing[1].alt} ratio="3 / 2"
          sizes="(max-width: 760px) 86vw, 40vw" />
      </div>
    </div>

    <div class="closing__cta reveal">
      <p class="closing__q"><em>Can you picture your story in our frames?</em></p>
      <a href="/contact/" class="cta">Get in touch</a>
    </div>
  </div>
</section>

<style>
  .closing__inner { display: grid; gap: clamp(3rem, 8vw, 6rem); }
  .closing__head {
    font-size: var(--fs-h1);
    font-weight: 340;
    max-width: 18ch;
    line-height: 1.16;
  }
  .closing__body {
    display: grid;
    grid-template-columns: 0.9fr 1fr 1.1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .closing__img--a { max-width: 28rem; }
  .closing__img--b { max-width: 40rem; align-self: end; }
  .closing__text { display: grid; gap: 1.4rem; }
  .closing__text p { color: var(--ink-soft); }

  .closing__cta { text-align: center; display: grid; gap: 1.6rem; }
  .closing__q { font-size: var(--fs-h3); }

  @media (max-width: 760px) {
    .closing__body { grid-template-columns: 1fr; justify-items: center; text-align: center; }
    .closing__text { max-width: 40ch; }
    .closing__head { margin-inline: auto; text-align: center; }
  }
</style>
