---
import Frame from '../Frame.astro';
import { heroMain, heroSecondary } from '../../data/photos';
---

<section class="hero">
  <div class="container hero__grid">
    <p class="hero__eyebrow eyebrow">
      Wedding storytellers · based in India<br />
      for heartfelt, unscripted celebrations
    </p>

    <h1 class="hero__stack">
      <span class="w w-lg">Candid</span>
      <span class="w w-lg">Raw</span>
      <span class="w w-lg">Timeless</span>
      <span class="w w-lg"><em>Emotive</em></span>
      <span class="w w-sm">&amp; entirely</span>
      <span class="w w-lg">Yours</span>
    </h1>

    <div class="hero__portrait">
      <Frame
        image={heroMain.image}
        alt={heroMain.alt}
        ratio="2 / 3"
        priority={true}
        sizes="(max-width: 820px) 92vw, 46vw"
        widths={[600, 900, 1200, 1500]}
      />
    </div>

    <div class="hero__second">
      <Frame
        image={heroSecondary.image}
        alt={heroSecondary.alt}
        ratio="3 / 4"
        sizes="(max-width: 820px) 86vw, 34vw"
        widths={[500, 800, 1100]}
      />
    </div>

    <div class="hero__caption">
      <p class="lead">
        Based in India — documenting weddings and celebrations across
        the country and beyond.
      </p>
      <a href="/contact/" class="cta">Check availability</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(7rem, 14vh, 11rem);
    padding-bottom: var(--section-y);
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    grid-template-areas:
      'eyebrow  portrait'
      'stack    portrait'
      'second   caption';
    column-gap: clamp(2rem, 6vw, 6rem);
    row-gap: clamp(2.5rem, 6vw, 6rem);
    align-items: center;
  }

  .hero__eyebrow {
    grid-area: eyebrow;
    align-self: end;
    line-height: 1.9;
  }

  .hero__stack {
    grid-area: stack;
    align-self: start;
    display: grid;
    text-transform: uppercase;
  }
  .w { display: block; }
  .w-lg {
    font-size: var(--fs-display);
    line-height: 0.92;
    font-weight: 360;
    letter-spacing: -0.012em;
  }
  .w-lg em { font-weight: 340; }
  .w-sm {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    font-size: clamp(0.8rem, 1.5vw, 1.05rem);
    padding: 0.55rem 0 0.7rem 0.3em;
    color: var(--ink-soft);
  }
  /* artful per-line offsets */
  .w:nth-child(2) { margin-left: 0.7em; }
  .w:nth-child(3) { margin-left: 0.15em; }
  .w:nth-child(4) { margin-left: 1.1em; }
  .w:nth-child(6) { margin-left: 0.45em; }

  .hero__portrait { grid-area: portrait; }
  .hero__second { grid-area: second; max-width: 30rem; }
  .hero__caption {
    grid-area: caption;
    display: grid;
    gap: 1.6rem;
    max-width: 26rem;
  }
  .hero__caption .lead { font-style: italic; }

  @media (max-width: 820px) {
    .hero {
      padding-top: clamp(6rem, 16vh, 9rem);
      text-align: center;
    }
    .hero__grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        'portrait'
        'eyebrow'
        'stack'
        'second'
        'caption';
      row-gap: clamp(2rem, 7vw, 3rem);
      justify-items: center;
    }
    .hero__stack { justify-items: center; }
    .w:nth-child(n) { margin-left: 0; }
    .hero__portrait { width: min(92%, 30rem); }
    .hero__second { width: min(80%, 22rem); }
    .hero__caption { justify-items: center; }
  }
</style>
