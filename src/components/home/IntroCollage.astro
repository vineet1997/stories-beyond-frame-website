---
import Frame from '../Frame.astro';
import { places, documentary } from '../../data/photos';
---

<section class="intro section">
  <div class="container">
    <!-- "Where our work takes us" — a frame + the places line (kept separate) -->
    <div class="intro__row intro__row--places">
      <div class="intro__img intro__img--tall reveal">
        <Frame image={places[0].image} alt={places[0].alt} ratio="2 / 3"
          sizes="(max-width: 760px) 86vw, 38vw" />
      </div>
      <div class="intro__places reveal">
        <p class="intro__places-text">
          From the palaces of Udaipur,<br />
          to a sunlit farmhouse in Delhi,<br />
          to the shores of Goa,<br />
          and the ghats of Varanasi —<br />
          <em>our work moves wherever love unfolds.</em>
        </p>
        <div class="intro__img-sm reveal">
          <Frame image={places[1].image} alt={places[1].alt} ratio="3 / 2"
            sizes="(max-width: 760px) 86vw, 30vw" />
        </div>
      </div>
    </div>

    <!-- The "documentary" composition: 4 frames in an offbeat, overlapping cascade -->
    <div class="doc">
      <div class="doc__txt doc__statement reveal">
        <p class="eyebrow">Documentary wedding photography</p>
        <p class="doc__line">rooted in <em>presence</em>, guided by <em>story</em></p>
      </div>

      <p class="doc__txt doc__lead reveal">
        We don't just capture moments — we capture <em>emotions</em>,
        <em>traditions</em>, and the magic of your love story.
      </p>

      <p class="doc__txt doc__closing reveal">
        <em>Emotion and love — at the heart of every frame.</em>
      </p>

      <figure class="doc__photo doc__p1 reveal">
        <Frame image={documentary[0].image} alt={documentary[0].alt} ratio="2 / 3"
          sizes="(max-width: 760px) 72vw, 20vw" widths={[300, 500, 700]} />
      </figure>
      <figure class="doc__photo doc__p2 reveal">
        <Frame image={documentary[1].image} alt={documentary[1].alt} ratio="3 / 2"
          sizes="(max-width: 760px) 64vw, 30vw" widths={[400, 700, 900]} />
      </figure>
      <figure class="doc__photo doc__p3 reveal">
        <Frame image={documentary[2].image} alt={documentary[2].alt} ratio="2 / 3"
          sizes="(max-width: 760px) 80vw, 18vw" widths={[300, 500, 700]} />
      </figure>
      <figure class="doc__photo doc__p4 reveal">
        <Frame image={documentary[3].image} alt={documentary[3].alt} ratio="3 / 4"
          sizes="(max-width: 760px) 55vw, 16vw" widths={[300, 500, 600]} />
      </figure>
    </div>

    <div class="intro__cta reveal">
      <a href="/experience/" class="cta">Work with us</a>
    </div>
  </div>
</section>

<style>
  /* ---- Movement 1: where our work takes us ---- */
  .intro__row {
    display: grid;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .intro__row--places {
    grid-template-columns: 0.85fr 1fr;
    margin-bottom: clamp(4.5rem, 12vw, 10rem);
  }
  .intro__img--tall { max-width: 30rem; }
  .intro__places { display: grid; gap: 2.5rem; max-width: 34rem; }
  .intro__places-text { font-size: var(--fs-h3); line-height: 1.5; font-weight: 350; }
  .intro__places-text em { color: var(--ink); }
  .intro__img-sm { max-width: 24rem; margin-left: auto; }

  /* ---- Movement 2: the offbeat documentary cascade ---- */
  .doc {
    position: relative;
    width: 100%;
    aspect-ratio: 1.62;
    margin-top: clamp(3rem, 8vw, 7rem);
  }
  .doc__photo {
    position: absolute;
    margin: 0;
    background: #faf7f0;
    padding: clamp(5px, 0.5vw, 9px);
    box-shadow: 0 22px 48px -32px rgba(28, 26, 23, 0.5);
  }
  .doc__txt { position: absolute; z-index: 3; }
  .doc__statement .eyebrow { display: block; }
  .doc__line { font-size: var(--fs-h3); font-weight: 350; margin-top: 0.8rem; }
  .doc__line em { font-style: italic; }
  .doc__lead { font-size: var(--fs-lead); font-weight: 350; line-height: 1.5; }
  .doc__lead em { font-style: italic; }
  .doc__closing { font-size: var(--fs-h3); font-weight: 340; }
  .doc__closing em { font-style: italic; }

  .doc__p1 { left: 20%; top: 2%;  width: 17%; z-index: 1; }
  .doc__p2 { left: 31%; top: 36%; width: 23%; z-index: 2; }
  .doc__p3 { left: 50%; top: 14%; width: 17%; z-index: 3; }
  .doc__p4 { left: 64%; top: 44%; width: 16%; z-index: 4; }
  .doc__statement { left: 0%;  top: 14%; width: 17%; }
  .doc__lead      { left: 81%; top: 15%; width: 18%; }
  .doc__closing   { left: 0%;  top: 54%; width: 18%; }

  .intro__cta { text-align: center; margin-top: clamp(3.5rem, 8vw, 7rem); }

  @media (max-width: 900px) {
    .intro__row--places { grid-template-columns: 1fr; justify-items: center; text-align: center; }
    .intro__places { justify-items: center; }
    .intro__img-sm { margin: 0 auto; }

    /* Cascade collapses to a staggered, overlapping pair, then a centered column */
    .doc {
      aspect-ratio: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: clamp(1.5rem, 5vw, 2.4rem);
      margin-top: clamp(2.5rem, 9vw, 4rem);
    }
    .doc__photo,
    .doc__txt { position: static; inset: auto; width: auto; margin: 0; }
    .doc__txt { text-align: center; max-width: 32ch; z-index: auto; }
    .doc__p1 { order: 1; align-self: flex-start; width: 72%; position: relative; z-index: 1; }
    .doc__p2 { order: 2; align-self: flex-end; width: 62%; margin-top: -14%; position: relative; z-index: 2; }
    .doc__statement { order: 3; }
    .doc__p3 { order: 4; width: 78%; }
    .doc__lead { order: 5; }
    .doc__p4 { order: 6; width: 58%; }
    .doc__closing { order: 7; }
  }
</style>
