---
import { site } from '../data/site';
const hasKey = site.web3formsKey.trim().length > 0;
---

<form
  class="cform"
  id="contact-form"
  method="POST"
  action="https://api.web3forms.com/submit"
  data-demo={hasKey ? undefined : 'true'}
>
  <input type="hidden" name="access_key" value={site.web3formsKey} />
  <input type="hidden" name="subject" value="New enquiry — Stories Beyond Frames" />
  <input type="hidden" name="from_name" value="Stories Beyond Frames website" />
  <!-- honeypot -->
  <input type="checkbox" name="botcheck" class="cform__hp" tabindex="-1" autocomplete="off" />

  <div class="cform__grid">
    <p class="cform__field">
      <label for="cf-name">Your names</label>
      <input id="cf-name" name="name" type="text" required autocomplete="name" placeholder="Aisha & Rohan" />
    </p>
    <p class="cform__field">
      <label for="cf-email">Email</label>
      <input id="cf-email" name="email" type="email" required autocomplete="email" placeholder="you@email.com" />
    </p>
    <p class="cform__field">
      <label for="cf-date">Wedding date</label>
      <input id="cf-date" name="wedding_date" type="text" autocomplete="off" placeholder="December 2026" />
    </p>
    <p class="cform__field">
      <label for="cf-venue">Venue / city</label>
      <input id="cf-venue" name="venue" type="text" autocomplete="off" placeholder="Udaipur, Rajasthan" />
    </p>
    <p class="cform__field cform__field--full">
      <label for="cf-message">Tell us about your celebration</label>
      <textarea id="cf-message" name="message" rows="4" required placeholder="We'd love to hear your story…"></textarea>
    </p>
  </div>

  <div class="cform__foot">
    <button type="submit" class="cform__submit cta">Send enquiry</button>
    <span class="cform__status" data-status role="status" aria-live="polite"></span>
  </div>
</form>

<style>
  .cform { max-width: 50rem; margin-inline: auto; }
  .cform__hp { position: absolute; left: -9999px; opacity: 0; }
  .cform__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.6rem, 3.5vw, 2.6rem) clamp(1.6rem, 4vw, 3rem);
  }
  .cform__field { display: grid; gap: 0.7rem; }
  .cform__field--full { grid-column: 1 / -1; }
  .cform label {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: 0.68rem;
    color: var(--stone);
  }
  .cform input,
  .cform textarea {
    border: 0;
    border-bottom: 1px solid var(--line);
    background: transparent;
    padding: 0.5rem 0;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--ink);
    transition: border-color 0.4s var(--ease);
  }
  .cform textarea { resize: vertical; }
  .cform input::placeholder,
  .cform textarea::placeholder { color: var(--stone); opacity: 0.6; }
  .cform input:focus,
  .cform textarea:focus { outline: none; border-color: var(--ink); }

  .cform__foot {
    margin-top: clamp(2.2rem, 5vw, 3.2rem);
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .cform__submit { border: 0; background: none; }
  .cform__status {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    color: var(--accent-deep);
  }
  .cform.is-sent .cform__grid,
  .cform.is-sent .cform__foot { display: none; }
  .cform__sent {
    font-size: var(--fs-h3);
    font-family: var(--font-serif);
    font-style: italic;
    text-align: center;
    padding-block: 2rem;
  }
  .cform__sent[hidden] { display: none; }

  @media (max-width: 600px) {
    .cform__grid { grid-template-columns: 1fr; }
  }
</style>

<div class="cform__sent" hidden></div>

<script>
  function initContactForm() {
    const form = document.querySelector<HTMLFormElement>('#contact-form');
    if (!form || form.dataset.bound) return;
    form.dataset.bound = 'true';
    const status = form.querySelector<HTMLElement>('[data-status]');
    const isDemo = form.dataset.demo === 'true';

    const showSent = () => {
      const sent = form.parentElement?.querySelector<HTMLElement>('.cform__sent');
      if (sent) {
        sent.textContent = 'Thank you — your note is on its way. We’ll be in touch very soon.';
        sent.hidden = false;
        form.classList.add('is-sent');
        sent.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (status) status.textContent = '';

      // Demo mode: no access key configured — simulate a successful send.
      if (isDemo) {
        if (status) status.textContent = 'Sending…';
        setTimeout(showSent, 600);
        return;
      }

      if (status) status.textContent = 'Sending…';
      try {
        const res = await fetch(form.action, { method: 'POST', body: new FormData(form) });
        const data = await res.json();
        if (data.success) showSent();
        else if (status) status.textContent = 'Something went wrong — please email us directly.';
      } catch {
        if (status) status.textContent = 'Network error — please email us directly.';
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:page-load', initContactForm);
</script>
