---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  sizes?: string;
  widths?: number[];
  class?: string;
  loading?: 'lazy' | 'eager';
  priority?: boolean;
  /** Force an aspect ratio, e.g. "2/3" or "3/2". Omit to keep natural ratio. */
  ratio?: string;
}

const {
  image,
  alt,
  sizes = '(max-width: 760px) 92vw, 33vw',
  widths,
  class: cls = '',
  loading,
  priority = false,
  ratio,
} = Astro.props;

// Cap requested widths at the source width to avoid upscaling.
const base = [400, 700, 1000, 1400, 1900];
const computedWidths = (widths ?? base).filter((w) => w <= image.width);
if (computedWidths.length === 0) computedWidths.push(image.width);

const style = ratio ? `aspect-ratio:${ratio};` : '';
---

<figure class={`frame ${cls}`} style={style} data-ratio={ratio ? '' : undefined}>
  <Picture
    src={image}
    alt={alt}
    formats={['avif', 'webp']}
    widths={computedWidths}
    sizes={sizes}
    loading={loading ?? (priority ? 'eager' : 'lazy')}
    fetchpriority={priority ? 'high' : 'auto'}
    decoding="async"
    class="frame__img"
  />
</figure>

<style>
  .frame {
    position: relative;
    overflow: hidden;
    background: var(--bone-deep);
    margin: 0;
  }
  .frame :global(picture) {
    display: block;
  }
  .frame__img {
    width: 100%;
    height: auto;
    opacity: 0;
    transform: scale(1.03);
    transition:
      opacity 1.1s var(--ease-out),
      transform 1.8s var(--ease-out);
  }
  .frame__img.is-loaded {
    opacity: 1;
    transform: none;
  }
  /* Fixed-ratio mode: cover-crop inside the figure */
  .frame[data-ratio] :global(picture) {
    position: absolute;
    inset: 0;
    height: 100%;
  }
  .frame[data-ratio] .frame__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
