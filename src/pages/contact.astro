---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactForm from '../components/ContactForm.astro';
import Frame from '../components/Frame.astro';
import { site } from '../data/site';
import { contactHero } from '../data/photos';
---

<BaseLayout
  title="Contact"
  description="Tell Stories Beyond Frames about your celebration. Based in India, available worldwide."
>
  <PageHeader
    eyebrow="Contact"
    title="Where your story <em>begins</em>."
    intro="Tell us a little about the two of you and your celebration. We reply to every note personally, usually within a couple of days."
  />

  <section class="section contact">
    <div class="container contact__grid">
      <div class="contact__form reveal">
        <ContactForm />
      </div>

      <aside class="contact__aside reveal">
        <div class="contact__details">
          <div class="contact__detail">
            <span class="eyebrow">Email</span>
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </div>
          <div class="contact__detail">
            <span class="eyebrow">Instagram</span>
            <a href={site.instagram.url} target="_blank" rel="noopener">{site.instagram.handle}</a>
          </div>
          <div class="contact__detail">
            <span class="eyebrow">Phone</span>
            <a href={site.phone.href}>{site.phone.label}</a>
          </div>
          <div class="contact__detail">
            <span class="eyebrow">Studio</span>
            <span>Based in India — available worldwide</span>
          </div>
        </div>
        <div class="contact__img">
          <Frame image={contactHero.image} alt={contactHero.alt} ratio="3 / 4"
            sizes="(max-width: 900px) 80vw, 26vw" />
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: clamp(2.5rem, 7vw, 6rem);
    align-items: start;
  }
  .contact__aside { display: grid; gap: clamp(2rem, 4vw, 3rem); }
  .contact__details { display: grid; gap: 1.6rem; }
  .contact__detail { display: grid; gap: 0.4rem; }
  .contact__detail .eyebrow { margin-bottom: 0.1rem; }
  .contact__detail a,
  .contact__detail span:not(.eyebrow) { font-size: 1.1rem; }
  .contact__detail a { transition: color 0.3s var(--ease); }
  .contact__detail a:hover { color: var(--accent-deep); }
  .contact__img { max-width: 22rem; }

  @media (max-width: 900px) {
    .contact__grid { grid-template-columns: 1fr; }
    .contact__form { order: 2; }
    .contact__aside {
      order: 1;
      grid-template-columns: 1fr;
    }
    .contact__details {
      grid-template-columns: 1fr 1fr;
    }
    .contact__img { display: none; }
  }
  @media (max-width: 480px) {
    .contact__details { grid-template-columns: 1fr; }
  }
</style>
